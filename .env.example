# Banco de dados - substitua com seus dados do PostgreSQL
DATABASE_URL="postgresql://postgres:vrydatabase@localhost:5432/jwt_api_db"

# Segredos JWT - troque por strings longas e aleatórias
JWT_SECRET="seu_jwt_secret_super_secreto_aqui_minimo_32_chars"
JWT_REFRESH_SECRET="seu_refresh_secret_super_secreto_aqui_minimo_32_chars"

# Expiração dos tokens
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Porta do servidor
PORT=3000
